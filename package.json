{
  "name": "wolbarg",
  "version": "0.4.0",
  "description": "Wolbarg — modular, provider-agnostic semantic memory SDK for AI agents. SQLite + PostgreSQL, hybrid search, ingest, optional rerankers.",
  "license": "MIT",
  "author": {
    "name": "Atharv Munde",
    "url": "https://github.com/Atharvmunde11"
  },
  "keywords": [
    "wolbarg",
    "Wolbarg",
    "ai",
    "agents",
    "ai-agents",
    "multi-agent",
    "multi-agent-systems",
    "memory",
    "agent-memory",
    "semantic-memory",
    "shared-memory",
    "embeddings",
    "vector-search",
    "vector-database",
    "sqlite",
    "sqlite-vec",
    "local-first",
    "offline-first",
    "rag",
    "typescript",
    "nodejs",
    "openai",
    "ollama",
    "llm",
    "langchain-alternative",
    "autonomous-agents",
    "semantic-search",
    "benchmarks"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsup && node scripts/fix-dist-imports.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "dependencies": {
    "sqlite-vec": "^0.1.6"
  },
  "peerDependencies": {
    "pg": "^8.13.0",
    "pdf-parse": "^1.1.4 || ^2.0.0",
    "mammoth": "^1.8.0",
    "tesseract.js": "^5.1.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "pdf-parse": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "tesseract.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.11.11",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolbarg/wolbarg.git"
  },
  "bugs": {
    "url": "https://github.com/wolbarg/wolbarg/issues"
  },
  "homepage": "https://github.com/wolbarg/wolbarg#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/wolbarg/wolbarg"
  },
  "optionalDependencies": {
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.22.0"
  }
}
